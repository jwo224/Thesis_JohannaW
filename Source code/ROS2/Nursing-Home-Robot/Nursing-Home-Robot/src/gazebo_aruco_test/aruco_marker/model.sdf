<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="aruco_marker">
    <static>true</static>

    <link name="marker_link">
      <!-- x y z roll pitch yaw -->
      <pose>2 0 0.2 0 0 0</pose>

      <visual name="marker_visual">
        <geometry>
          <box>
            <!-- width thickness height -->
            <size>0.2 0.01 0.2</size>
          </box>
        </geometry>

        <material>
          <script>
            <uri>model://aruco_marker/materials/scripts</uri>
            <uri>model://aruco_marker/materials/textures</uri>
            <name>Aruco/Marker0</name>
          </script>
        </material>
      </visual>

      <collision name="marker_collision">
        <geometry>
          <box>
            <size>0.2 0.01 0.2</size>
          </box>
        </geometry>
      </collision>
    </link>
  </model>
</sdf>