<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >

    <xacro:include filename="inertial_macros.xacro"/>

	<!-- =========================
	       Base (Main body mesh)
	       Dimensions from your drawing:
	       - length: 472 mm -> 0.472 m
	       - width : 515 mm -> 0.515 m
	       - height: 196 mm -> 0.196 m (top to bottom plate not ground)
		   -distance to floor: 25.5mm -> 0.0255 m
	       
	
	       ========================= -->
	  <link name="base_link">
	    <inertial>
	      <origin xyz="0 0 0" rpy="0 0 0"/>
	      <mass value="25.0"/>
	      <inertia ixx="0.2" ixy="0.0" ixz="0.0"
		       iyy="0.2" iyz="0.0"
		       izz="0.2"/>
	    </inertial>

          <visual>
	      <origin xyz="0 0 0.1235" rpy="0 0 0"/>
	      <geometry>
	        <box size="0.472 0.515 0.196"/>
	      </geometry>
	      <material name="green">
	         <color rgba="0.2 1 0.2 1"/>
	      </material>
	  </visual>

          <!-- Retractable trolley support pins shown retracted during approach.
               Keep these visual-only until the physical actuator/joint is added. -->
          <visual>
	      <origin xyz="0.090175 0 0.2265" rpy="0 0 0"/>
	      <geometry>
	        <cylinder radius="0.011" length="0.010"/>
	      </geometry>
	      <material name="dark_grey">
	         <color rgba="0.15 0.15 0.15 1"/>
	      </material>
	  </visual>

          <visual>
	      <origin xyz="-0.090175 0 0.2265" rpy="0 0 0"/>
	      <geometry>
	        <cylinder radius="0.011" length="0.010"/>
	      </geometry>
	      <material name="dark_grey">
	         <color rgba="0.15 0.15 0.15 1"/>
	      </material>
	  </visual>



	    <!-- Simple collision box using your real robot size -->
	    <collision>
	      <origin xyz="0 0 0.1235" rpy="0 0 0"/>
	      <geometry>
		<box size="0.472 0.515 0.196"/>
	      </geometry>
	    </collision>
	  </link>

	  <!-- =========================
	       Wheels
	       ========================= -->

	  <!-- Front Left wheel -->
	  <link name="wheel_fl">
	    <visual>
	      <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
	      <geometry>
                 <cylinder radius="0.0635" length="0.051"/>
              </geometry>
	      <material name="blue" />
	    </visual>
	    <collision>
	      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
	      <geometry>
		<!-- wheel radius/width are placeholders -->
		<cylinder radius="0.0635" length="0.051"/>
	      </geometry>
	    </collision>
	    <inertial>
	      <origin xyz="0 0 0" rpy="0 0 0"/>
	      <mass value="0.8"/>
	      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
		       iyy="0.01" iyz="0.0"
		       izz="0.01"/>
	    </inertial>
	  </link>

	  <!-- Front Right wheel -->
	  <link name="wheel_fr">
	    <visual>
	      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
	      <geometry>
                 <cylinder radius="0.0635" length="0.051"/>
              </geometry>
	      <material name="blue" />
	    </visual>
	    <collision>
	      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
	      <geometry>
		<cylinder radius="0.0635" length="0.051"/>
	      </geometry>
	    </collision>
	    <inertial>
	      <origin xyz="0 0 0" rpy="0 0 0"/>
	      <mass value="0.8"/>
	      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
		       iyy="0.01" iyz="0.0"
		       izz="0.01"/>
	    </inertial>
	  </link>

	  <!-- Rear Left wheel -->
	  <link name="wheel_rl">
	    <visual>
	      <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
	      <geometry>
                 <cylinder radius="0.0635" length="0.051"/>
              </geometry>
	      <material name="blue" />
	    </visual>
	    <collision>
	      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
	      <geometry>
		<cylinder radius="0.0635" length="0.051"/>
	      </geometry>
	    </collision>
	    <inertial>
	      <origin xyz="0 0 0" rpy="0 0 0"/>
	      <mass value="0.8"/>
	      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
		       iyy="0.01" iyz="0.0"
		       izz="0.01"/>
	    </inertial>
	  </link>

	  <!-- Rear Right wheel -->
	  <link name="wheel_rr">
	    <visual>
	      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
	      <geometry>
                 <cylinder radius="0.0635" length="0.051"/>
              </geometry>
	      <material name="blue" />
	    </visual>
	    <collision>
	      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
	      <geometry>
		<cylinder radius="0.0635" length="0.051"/>
	      </geometry>
	    </collision>
	    <inertial>
	      <origin xyz="0 0 0" rpy="0 0 0"/>
	      <mass value="0.8"/>
	      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
		       iyy="0.01" iyz="0.0"
		       izz="0.01"/>
	    </inertial>
	  </link>

	  <!-- =========================
	       Wheel joints
	       - wheelbase (front-rear): 403.80 mm -> 0.4038 m -> half = 0.2019
	       - track (left-right):     295.00 mm -> 0.2950 m -> half = 0.1475
	       Wheel Z is set to 0.05 (assumes 100mm wheel diameter).
	       Change Z to match your wheel radius.
	       ========================= -->

	  <!-- Front Left -->
	  <joint name="wheel_fl_joint" type="continuous">
	    <parent link="base_link"/>
	    <child link="wheel_fl"/>
	    <origin xyz="0.1475 0.2019 0.0635" rpy="0 0 0"/>
	    <axis xyz="0 1 0"/>
	  </joint>

	  <!-- Front Right -->
	  <joint name="wheel_fr_joint" type="continuous">
	    <parent link="base_link"/>
	    <child link="wheel_fr"/>
	    <origin xyz="-0.1475 0.2019 0.0635" rpy="0 0 0"/>
	    <axis xyz="0 1 0"/>
	  </joint>

	  <!-- Rear Left -->
	  <joint name="wheel_rl_joint" type="continuous">
	    <parent link="base_link"/>
	    <child link="wheel_rl"/>
	    <origin xyz="0.1475 -0.2019 0.0635" rpy="0 0 0"/>
	    <axis xyz="0 1 0"/>
	  </joint>

	  <!-- Rear Right -->
	  <joint name="wheel_rr_joint" type="continuous">
	    <parent link="base_link"/>
	    <child link="wheel_rr"/>
	    <origin xyz="-0.1475 -0.2019 0.0635" rpy="0 0 0"/>
	    <axis xyz="0 1 0"/>
	  </joint>
	  
	 
  
  </robot>
