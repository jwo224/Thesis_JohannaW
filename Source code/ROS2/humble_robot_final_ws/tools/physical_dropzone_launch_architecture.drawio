              <mxPoint x="1245" y="725" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e_stage_side_drive" edge="1" parent="1" source="stage_side" target="stage_drive" value="operator approves next stage" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_stage_drive_fine" edge="1" parent="1" source="stage_drive" target="stage_fine" value="operator approves next stage" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
