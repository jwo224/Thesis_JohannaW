        <mxCell id="e_alignment_stage_side" edge="1" parent="1" source="alignment" target="stage_side" value="side_align" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry">
