          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_base_alignment" edge="1" parent="1" source="base" target="alignment" value="/odom, /tf, /tf_static" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="560" y="988" />
