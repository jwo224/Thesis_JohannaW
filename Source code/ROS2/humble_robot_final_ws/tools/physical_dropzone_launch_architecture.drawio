            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e_alignment_stage_drive" edge="1" parent="1" source="alignment" target="stage_drive" value="drive_under" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_alignment_stage_fine" edge="1" parent="1" source="alignment" target="stage_fine" value="fine_align" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry">
