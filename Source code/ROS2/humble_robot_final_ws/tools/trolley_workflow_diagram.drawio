<mxfile host="app.diagrams.net">
  <diagram name="Trolley Workflow" id="trolley-workflow-diagram">
    <mxGraphModel dx="1500" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Staged Trolley Workflow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=26;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="25" width="1000" height="45" as="geometry" />
        </mxCell>

        <mxCell id="start" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;Robot at charging / ready pose" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontColor=#111111;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="70" y="120" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="approach" value="&lt;b&gt;1. Approach trolley&lt;/b&gt;&lt;br&gt;Command: trolley_ready&lt;br&gt;Nav2 goal to staging pose&lt;br&gt;Topic: /goal_pose_raw" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e11b0c;strokeColor=#111111;fontColor=#ffffff;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="330" y="105" width="260" height="110" as="geometry" />
        </mxCell>

        <mxCell id="side_align" value="&lt;b&gt;2. Side alignment&lt;/b&gt;&lt;br&gt;Command: side_align&lt;br&gt;Left/right ArUco side markers&lt;br&gt;Direct /cmd_vel alignment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e11b0c;strokeColor=#111111;fontColor=#ffffff;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="670" y="105" width="280" height="110" as="geometry" />
        </mxCell>

        <mxCell id="classify" value="&lt;b&gt;3. Classify trolley&lt;/b&gt;&lt;br&gt;Command: check_trolley_type&lt;br&gt;Enable YOLO detector&lt;br&gt;Output: /Yolov8_Inference" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e11b0c;strokeColor=#111111;fontColor=#ffffff;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="1040" y="105" width="300" height="110" as="geometry" />
        </mxCell>

        <mxCell id="decision" value="Trolley class?&lt;br&gt;empty / laundry / trash" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontColor=#111111;fontStyle=1;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1125" y="300" width="130" height="100" as="geometry" />
        </mxCell>

        <mxCell id="empty" value="&lt;b&gt;Empty trolley&lt;/b&gt;&lt;br&gt;Cancel loaded-trolley delivery&lt;br&gt;Return / wait for next task" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f8f8;strokeColor=#6a4aa3;fontColor=#111111;fontStyle=1;fontSize=14;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="1260" y="465" width="210" height="90" as="geometry" />
        </mxCell>

        <mxCell id="drive_under" value="&lt;b&gt;4. Drive under trolley&lt;/b&gt;&lt;br&gt;Command: drive_under&lt;br&gt;Odometry distance + marker check&lt;br&gt;Direct /cmd_vel motion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e11b0c;strokeColor=#111111;fontColor=#ffffff;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="800" y="480" width="300" height="115" as="geometry" />
        </mxCell>

        <mxCell id="fine_align" value="&lt;b&gt;5. Fine alignment&lt;/b&gt;&lt;br&gt;Command: fine_align&lt;br&gt;Front/rear underside ArUco&lt;br&gt;Correct yaw, Y, then X" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e11b0c;strokeColor=#111111;fontColor=#ffffff;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="455" y="480" width="290" height="115" as="geometry" />
        </mxCell>

        <mxCell id="dock" value="&lt;b&gt;6. Dock / attach&lt;/b&gt;&lt;br&gt;Robot positioned under trolley&lt;br&gt;Mechanical docking step&lt;br&gt;Operator verifies result" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e11b0c;strokeColor=#111111;fontColor=#ffffff;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="120" y="480" width="280" height="115" as="geometry" />
        </mxCell>

        <mxCell id="deliver" value="&lt;b&gt;7. Deliver trolley&lt;/b&gt;&lt;br&gt;Command: deliver_trolley&lt;br&gt;Laundry or trash drop-off goal&lt;br&gt;Map-based navigation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e11b0c;strokeColor=#111111;fontColor=#ffffff;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="120" y="690" width="280" height="110" as="geometry" />
        </mxCell>

        <mxCell id="drive_out" value="&lt;b&gt;8. Drive out / release&lt;/b&gt;&lt;br&gt;Command: drive_out&lt;br&gt;Direct velocity release motion&lt;br&gt;/cmd_vel and /cmd_vel_joy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e11b0c;strokeColor=#111111;fontColor=#ffffff;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="470" y="690" width="290" height="110" as="geometry" />
        </mxCell>

        <mxCell id="return" value="&lt;b&gt;9. Return to charging&lt;/b&gt;&lt;br&gt;Command: charging / return&lt;br&gt;Nav2 goal to charging pose" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e11b0c;strokeColor=#111111;fontColor=#ffffff;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="825" y="690" width="290" height="110" as="geometry" />
        </mxCell>

        <mxCell id="end" value="&lt;b&gt;End&lt;/b&gt;&lt;br&gt;Ready for next supervised run" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontColor=#111111;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="1220" y="705" width="190" height="80" as="geometry" />
        </mxCell>

        <mxCell id="supervision" value="Operator supervision between stages:&lt;br&gt;the next command is sent only after visual/log inspection." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f8f8;strokeColor=#6a4aa3;fontColor=#111111;fontStyle=1;fontSize=14;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="80" y="315" width="405" height="80" as="geometry" />
        </mxCell>

        <mxCell id="e1" edge="1" parent="1" source="start" target="approach" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="1" source="approach" target="side_align" value="operator approves" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" edge="1" parent="1" source="side_align" target="classify" value="operator approves" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" edge="1" parent="1" source="classify" target="decision" value="detected class" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" edge="1" parent="1" source="decision" target="empty" value="empty" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#6a4aa3;dashed=1;dashPattern=5 5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" edge="1" parent="1" source="decision" target="drive_under" value="laundry / trash" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1190" y="430" />
              <mxPoint x="950" y="430" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e7" edge="1" parent="1" source="drive_under" target="fine_align" value="operator approves" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" edge="1" parent="1" source="fine_align" target="dock" value="alignment complete" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" edge="1" parent="1" source="dock" target="deliver" value="operator approves" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" edge="1" parent="1" source="deliver" target="drive_out" value="arrived at drop-off" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" edge="1" parent="1" source="drive_out" target="return" value="released" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" edge="1" parent="1" source="return" target="end" value="charging reached" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#111111;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13" edge="1" parent="1" source="empty" target="return" value="return / wait" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=13;strokeColor=#6a4aa3;dashed=1;dashPattern=5 5;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1365" y="745" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
